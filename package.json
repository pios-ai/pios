{
  "name": "pios",
  "productName": "PiOS",
  "version": "0.7.9",
  "description": "AI-native personal operating system",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --mac",
    "build:dir": "electron-builder --mac dir",
    "build:dmg": "electron-builder --mac dmg",
    "install:app": "bash scripts/install-app.sh",
    "_note_no_postbuild": "postbuild 自动 ditto 到 /Applications/PiOS.app 被主 mac 污染踩雷 2026-04-25，移除；改 DMG 手动装或 dev 模式 npm start",
    "postinstall": "bash scripts/patch-electron-name.sh"
  },
  "build": {
    "appId": "com.pios-ai.pios",
    "productName": "PiOS",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "dir"
      ],
      "extendInfo": {
        "NSUserNotificationAlertStyle": "alert",
        "NSAppleEventsUsageDescription": "PiOS 需要打开 Terminal 跑环境安装脚本（如 Homebrew）"
      }
    },
    "files": [
      "main.js",
      "preload.js",
      "pios-installer.js",
      "browser-preload.js",
      "pios-home.html",
      "quick-input.html",
      "auth-dialog.html",
      "renderer/**",
      "backend/**",
      "modules/**",
      "assets/**",
      "vendor/**",
      "node_modules/**",
      {
        "from": "node_modules/three",
        "to": "node_modules/three",
        "filter": [
          "examples/jsm/**/*"
        ]
      },
      "package.json",
      "icon.png",
      "tray-iconTemplate.png",
      "tray-iconTemplate@2x.png"
    ],
    "asarUnpack": [
      "node_modules/pdf2json/**",
      "node_modules/xlsx/**",
      "node_modules/mammoth/**",
      "renderer/assets/**",
      "node_modules/three/examples/jsm/libs/draco/**",
      "modules/afterward/**",
      "backend/tools/**"
    ],
    "extraResources": [
      {
        "from": "${env.HOME}/qwen-voice",
        "to": "qwen-voice",
        "filter": [
          "**/*",
          "!**/*.bak-*",
          "!**/*.new",
          "!share/**",
          "!ref_voices/owner.wav",
          "!ref_voices/feixia.wav",
          "!ref_voices/jupiter*.wav",
          "!ref_voices/pi.wav",
          "!ref_voices/xiaodou.wav"
        ]
      },
      {
        "from": "${env.HOME}/.cache/huggingface/hub/models--mlx-community--whisper-large-v3-turbo",
        "to": "qwen-voice-models/hub/models--mlx-community--whisper-large-v3-turbo"
      },
      {
        "from": "${env.HOME}/.cache/huggingface/hub/models--mlx-community--Qwen3-TTS-12Hz-0.6B-CustomVoice-4bit",
        "to": "qwen-voice-models/hub/models--mlx-community--Qwen3-TTS-12Hz-0.6B-CustomVoice-4bit"
      },
      {
        "from": "${env.HOME}/.cache/huggingface/hub/models--mlx-community--Qwen3-TTS-12Hz-0.6B-Base-4bit",
        "to": "qwen-voice-models/hub/models--mlx-community--Qwen3-TTS-12Hz-0.6B-Base-4bit"
      }
    ],
    "directories": {
      "output": "dist"
    }
  },
  "author": "PiOS",
  "dependencies": {
    "@pixiv/three-vrm": "^3.5.2",
    "form-data": "^4.0.5",
    "gray-matter": "^4.0.3",
    "https-proxy-agent": "^7.0.6",
    "js-yaml": "^4.1.1",
    "mammoth": "^1.12.0",
    "marked": "^15.0.0",
    "node-pty": "^1.1.0",
    "pdf-parse": "^2.4.5",
    "pdf2json": "^4.0.2",
    "three": "^0.184.0",
    "uuid": "^13.0.0",
    "ws": "^8.20.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8"
  }
}
