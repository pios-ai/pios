# PiOS Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real API keys.

# ── LLM API Keys ────────────────────────────────────────────────────────────────
# Set the key for whichever provider you use in config.yaml → llm.provider

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# For Ollama (local, no key needed):
# Set llm.provider=ollama and llm.base_url=http://ollama:11434 in config.yaml

# ── Port (optional override) ─────────────────────────────────────────────────
PIOS_PORT=9100
